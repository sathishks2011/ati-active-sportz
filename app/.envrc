# RN 0.85's prebuilt React-Core / React-Native-Dependencies tarballs use a
# Ruby URI::File.build call that chokes on paths containing spaces — and this
# repo lives under "My Workspace". Force pod install to build from source.
# Remove these once the project moves to a space-free path (or once RN patches
# the URI handling upstream).
export RCT_USE_PREBUILT_RNCORE=0
export RCT_USE_RN_DEP=0

# Active developer dir is wired via `xcode-select`, but if anything ever falls
# back to /Library/Developer/CommandLineTools, pin Xcode explicitly here.
export DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
